{%- assign events_blog = blogs[section.settings.blog] -%}

<section class="events-wrap">
    <h1>{{ page.title }}</h1>

    <div>
        <div id="events-calendar"></div>
    </div>

    {%- if events_blog -%}
        {%- assign now = 'now' | date: '%s' | plus: 0 -%}
        {%- assign has_events = false -%}

        <div class="events-list">
            {%- for article in events_blog.articles -%}
                {%- assign event_date = article.metafields.custom.event_date.value -%}
                {%- assign event_date_ts = event_date | date: '%s' | plus: 0 -%}
                {%- if event_date_ts >= now -%}
                    {%- assign has_events = true -%}
                    <div class="event-card">
                        {%- if article.image -%}
                            <div class="event-card__image">
                                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                            </div>
                        {%- endif -%}
                        <div class="event-card__content">
                            <p class="event-card__date">{{ event_date | date: '%A, %B %e, %Y' }}</p>
                            <h2>{{ article.title }}</h2>
                            {%- if article.excerpt -%}
                                <p>{{ article.excerpt }}</p>
                            {%- endif -%}
                            <a href="{{ article.url }}" class="button">Learn More</a>
                        </div>
                    </div>
                {%- endif -%}
            {%- endfor -%}
        </div>

        {%- unless has_events -%}
            <p class="events-empty">No upcoming events. Check back soon!</p>
        {%- endunless -%}
    {%- else -%}
        <p class="events-empty">No events blog selected. Please configure this section in the theme editor.</p>
    {%- endif -%}
</section>

