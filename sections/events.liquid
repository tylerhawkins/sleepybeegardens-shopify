{% stylesheet %}
    .fc-event-time, .fc-event-title {
        padding: 0 1px;
        white-space: normal;
    }

    /* .fc-event-title-container {
        position: relative;

        .fc-event-info {
            position: absolute;
            top: 100%;
            left: 0;
            z-index: 100;
        }
    } */

    .events-wrap {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 24px;

        h1 {
            margin-bottom: 40px;
        }

        .events-list {
            display: flex;
            flex-direction: column;
            gap: 40px;
        }

        .event-card {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 32px;
            align-items: start;

            @media (max-width: 759px) {
                grid-template-columns: 1fr;
            }

            .event-card__image {
                border-radius: 12px;
                overflow: hidden;
                aspect-ratio: 4/3;

                img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }
            }

            .event-card__content {
                display: flex;
                flex-direction: column;
                gap: 12px;
            }

            .event-card__date {
                font-size: 14px;
                font-weight: bold;
                color: var(--color-green);
                text-transform: uppercase;
                letter-spacing: 0.05em;
                margin: 0;
            }

            h2 {
                margin: 0;
            }

            p {
                margin: 0;
            }
        }

        .events-empty {
            color: #666;
            font-style: italic;
        }
    }
{% endstylesheet %}

{% schema %}
{
    "name": "Events",
    "settings": [
        {
            "type": "blog",
            "id": "blog",
            "label": "Events blog"
        }
    ]
}
{% endschema %}
