{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<section class="cart-wrap">
    <h1>{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
        <form action="{{ routes.cart_url }}" method="post" class="cart-form">
            <div class="cart-items">
                {%- for item in cart.items -%}
                    <div class="cart-item">
                        <a href="{{ item.url }}" class="cart-item__image">
                            {% render 'image',
                                image: item.image,
                                width: 200,
                                crop: 'center'
                            %}
                        </a>

                        <div class="cart-item__details">
                            <a href="{{ item.url }}">{{ item.product.title }}</a>
                            {%- unless item.variant.title == 'Default Title' -%}
                                {%- for option in item.variant.options -%}
                                    <div class="cart-item__variant"><span>{{ item.product.options[forloop.index0] }}:</span> {{ option }}</div>
                                {%- endfor -%}
                            {%- endunless -%}
                            <div class="cart-item__price">{{ item.final_price | money }}</div>
                            <div class="cart-item__quantity atc-wrap">
                                <div class="quantity-wrap">
                                    <button type="button" class="quantity-btn decrement" aria-label="Decrease quantity">−</button>
                                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" aria-label="Quantity">
                                    <button type="button" class="quantity-btn increment" aria-label="Increase quantity">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="cart-item__total">
                            {{ item.final_line_price | money }}
                        </div>

                        <a href="{{ item.url_to_remove }}" class="cart-item__remove" aria-label="Remove" title="Remove">
                            {{ 'icon-trash.svg' | inline_asset_content }}
                        </a>
                    </div>
                {%- endfor -%}
            </div>

            <div class="cart-sidebar">
                <div class="cart-summary">
                    <div class="cart-subtotal">
                        <span>Subtotal</span>
                        <span>{{ cart.total_price | money }}</span>
                    </div>
                    <p class="cart-taxes">Taxes and shipping calculated at checkout</p>
                    <div class="cart-actions">
                        <button type="submit" name="checkout" class="button">Checkout</button>
                        <button type="submit" name="update" class="button button-secondary">Update Cart</button>
                    </div>
                </div>
            </div>
        </form>
    {%- else -%}
        <div class="cart-empty">
            <p>Your cart is empty.</p>
            <a href="{{ routes.collections_url }}" class="button">Continue Shopping</a>
        </div>
    {%- endif -%}
</section>

{% javascript %}
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.cart-item__quantity').forEach(wrap => {
            wrap.querySelector('.decrement').addEventListener('click', () => {
                const input = wrap.querySelector('input');
                if (input.value > 0) input.value = parseInt(input.value) - 1;
            });
            wrap.querySelector('.increment').addEventListener('click', () => {
                const input = wrap.querySelector('input');
                input.value = parseInt(input.value) + 1;
            });
        });
    });
{% endjavascript %}

{% stylesheet %}
    .cart-wrap {
        padding: 0 24px;

        h1 {
            margin-bottom: 40px;
        }
    }

    .cart-items {
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--color-grey);
    }

    .cart-item {
        display: grid;
        grid-template-columns: 200px 1fr auto 40px;
        gap: 24px;
        align-items: center;
        padding: 24px 0;
        border-bottom: 1px solid var(--color-grey);

        @media (max-width: 759px) {
            grid-template-columns: 80px 1fr auto;
            grid-template-rows: auto auto;
        }
    }

    .cart-item__image {
        border-radius: 8px;
        overflow: hidden;
        aspect-ratio: 1;

        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
    }

    .cart-item__details {
        display: flex;
        flex-direction: column;
        gap: 8px;

        a {
            align-self: self-start;
            font-weight: bold;
            text-decoration: none;
            color: var(--color-black);

            &:hover {
                text-decoration: underline;
            }
        }
    }

    .cart-item__variant {
        color: #666;
        font-size: 14px;

        span {
            font-weight: bold;
        }
    }

    .cart-item__price {
        font-size: 14px;
    }

    .cart-item__total {
        font-weight: bold;
        text-align: right;

        @media (max-width: 759px) {
            display: none;
        }
    }

    .cart-item__quantity {
        @media (max-width: 759px) {
            grid-column: 2;
        }
    }

    .cart-item__remove {
        display: flex;
        justify-content: flex-end;
        color: var(--color-black);
        transition: opacity 0.2s ease-in-out;
        --icon-stroke-width: 2px;

        &:hover {
            opacity: 0.6;
        }

        svg {
            width: 20px;
        }
    }

    .cart-form {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 48px;
        align-items: start;

        @media (max-width: 759px) {
            grid-template-columns: 1fr;
        }
    }

    .cart-sidebar {
        position: sticky;
        top: 24px;
    }

    .cart-summary {
        border: 1px solid var(--color-grey);
        border-radius: 12px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .cart-subtotal {
        display: flex;
        justify-content: space-between;
        font-size: 20px;
        font-weight: bold;
    }

    .cart-taxes {
        color: #666;
        font-size: 14px;
        margin: 0;
    }

    .cart-actions {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 8px;

        .button {
            width: 100%;
            text-align: center;
        }
    }

    .cart-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 24px;
        padding: 80px 0;
        text-align: center;

        p {
            font-size: 20px;
            margin: 0;
        }
    }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
