<div class="featured full-width">
    <div class="wave-divider"></div>
    <div class="wave-content">
        <h2>{{ section.settings.featured_heading }}</h2>
    
        {% if section.settings.collection != blank %}
            <div class="products">
                {% for product in section.settings.collection.products limit: 4 %}
                <div class="product-card">
                    <a href="{{ product.url }}">
                        <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" />
                        <h3>{{ product.title }}</h3>
                        <p>{{ product.price | money }}</p>
                    </a>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>

{% stylesheet %}
  .featured {
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured",
  "settings": [
    {
      "type": "text",
      "id": "featured_heading",
      "label": "Featured Heading",
      "default": "Featured Flowers"
    },
    {
      "type": "collection",
      "id": "featured_collection",
      "label": "Featured Collection"
    }
  ],
  "presets": [
    {
      "name": "Featured"
    }
  ]
}
{% endschema %}