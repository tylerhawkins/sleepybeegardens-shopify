<header class="full-width">
    <div class="header-inner">
        <div class="mobile-menu">
            <span id="menu-toggle" aria-expanded="false" aria-controls="mobile-nav">{{ 'icon-menu.svg' | inline_asset_content }}</span>
        </div>

        <a href="{{ routes.root_url }}" class="logo"><img src="{{ 'logo-header.svg' | asset_url }}" width="47" height="50" alt="{{ shop.name }}"></a>

        <div class="header__menu">
            {% for link in section.settings.menu.links %}
                {{ link.title | link_to: link.url }}
            {% endfor %}
        </div>

        <div class="header__icons">
            {% if shop.customer_accounts_enabled %}
                {%- assign account_url = 'https://shopify.com/' | append: shop.id | append: '/account' -%}
                {{ 'icon-account.svg' | inline_asset_content | link_to: account_url }}
            {% endif %}

            <a href="{{ routes.cart_url }}">
                {% if cart.item_count > 0 %}
                    <sup>{{ cart.item_count }}</sup>
                {% endif %}
                {{ 'icon-cart.svg' | inline_asset_content }}
            </a>
        </div>
    </div>

    <nav class="mobile-nav" id="mobile-nav" aria-hidden="true">
        {% for link in section.settings.menu.links %}
            {{ link.title | link_to: link.url }}
        {% endfor %}
    </nav>
    <div class="mobile-nav__overlay" id="mobile-nav-overlay"></div>
</header>

<script>
    const toggle = document.getElementById('menu-toggle');
    const nav = document.getElementById('mobile-nav');
    const overlay = document.getElementById('mobile-nav-overlay');

    function closeNav() {
        nav.classList.remove('is-open');
        overlay.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        nav.setAttribute('aria-hidden', 'true');
    }

    toggle.addEventListener('click', () => {
        const isOpen = nav.classList.toggle('is-open');
        overlay.classList.toggle('is-open');
        toggle.setAttribute('aria-expanded', isOpen);
        nav.setAttribute('aria-hidden', !isOpen);
    });

    overlay.addEventListener('click', closeNav);
</script>

{% stylesheet %}
    header {
        display: flex;
        flex-direction: column;
        position: relative;
        color: var(--color-white);
        background: var(--color-orange);

        .header-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 32px;
            max-width: 1536px;
            margin: 0 auto;
            width: 100%;

            @media (max-width: 959px) {
                padding-left: 16px;
                padding-right: 16px;
            }
        }

        &::after {
            content: '';
            display: block;
            height: 20px;
            background: var(--color-orange);
            -webkit-clip-path: url(#solid-uneven-waves-bottom-1);
            clip-path: url(#solid-uneven-waves-bottom-1);
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            z-index: 10;
            margin-top: -9px;
        }

        a {
            position: relative;
            text-decoration: none;
            color: var(--color-white);
        }

        svg {
            width: 2rem;

            @media (max-width: 959px) {
                width: 2.5rem;
            }
        }

        .header__menu {
            display: flex;
            gap: 2rem;

            @media (max-width: 959px) {
                display: none;
            }

            a {
                display: inline-block;
                font-size: 18px;

                &::after {
                    content: '';
                    position: absolute;
                    width: 100%;
                    transform: scaleX(0);
                    height: 2px;
                    bottom: -2px;
                    left: 0;
                    background-color: var(--color-white);
                    transition: transform 0.2s ease-out;
                }

                &:hover::after {
                    transform: scaleX(1);
                }
            }
        }

        .header__icons {
            display: flex;
            gap: 1rem;

            @media (max-width: 959px) {
                flex: 1;
                gap: .5rem;
                justify-content: flex-end;
            }

            a {
                display: inline-block;

                sup {
                    position: absolute;
                    left: 50%;
                    top: -3px;
                    z-index: 10;
                    background: var(--color-white);
                    color: var(--color-black);
                    border-radius: 100%;
                    padding: 4px;
                    font-size: 12px;
                    font-weight: bold;
                    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
                }

                svg {
                    transform-style: preserve-3d;
                    transition: opacity 0.2s ease-in-out;
                }

                &:hover svg {
                    opacity: 0.6;
                }
            }
        }

        .mobile-menu {
            @media (min-width: 960px) {
                display: none;
            }

            @media (max-width: 959px) {
                flex: 1;
            }

            span {
                display: block;
                width: fit-content;
                cursor: pointer;
            }
        }

        .mobile-nav {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            position: fixed;
            top: 0;
            left: 0;
            height: 100%;
            width: 80%;
            background: var(--color-orange);
            padding: 32px;
            z-index: 100;
            transform: translateX(-100%);
            transition: transform 0.3s ease;

            &.is-open {
                transform: translateX(0);
            }

            a {
                font-size: 20px;
                color: var(--color-white);
                text-decoration: none;
            }

            @media (min-width: 960px) {
                display: none;
            }
        }

        .mobile-nav__overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: 99;

            &.is-open {
                display: block;
            }

            @media (min-width: 960px) {
                display: none !important;
            }
        }
    }
{% endstylesheet %}

{% schema %}
{
    "name": "t:general.header",
    "settings": [
    {
        "type": "link_list",
        "id": "menu",
        "label": "t:labels.menu"
    }
  ]
}
{% endschema %}
