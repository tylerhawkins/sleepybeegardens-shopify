<section class="hero full-width" {% if section.settings.hero_background_image != blank %}style="background-image: url('{{ section.settings.hero_background_image | image_url: width: 2000 }}');"{% endif %}>
    <div class="hero-inner">
        <div class="content">
            <div class="text-wrap">
                <h1>{{ section.settings.heading }}</h1>
                <div class="action-group">
                    <a href="{{ section.settings.primary_button_link }}" class="button">{{ section.settings.primary_button_text }}</a>
                    <a href="{{ section.settings.secondary_button_link }}" class="button button-secondary">{{ section.settings.secondary_button_text }}</a>
                </div>
            </div>
        </div>
    </div>
</section>

{% stylesheet %}
  .hero {
    position: relative;
    width: 100%;
    height: 60vh;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;

    &::after {
      content: '';
      background: #00000060;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;;
    }

    .hero-inner {
      display: flex;
      flex-direction: row;
      align-items: center;
      position: relative;
      height: 100%;
    }

    .content {
      position: relative;
      z-index: 1;
      width: 100%;
      padding: 0 32px;
      column-gap: 32px;
      align-items: center;
      justify-content: center;
    }

    .text-wrap {
      color: var(--color-white);
      text-align: center;

      h1 {
        margin-bottom: 32px;
      }
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_background_image",
      "label": "Hero Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Locally Grown, Farm Fresh<br/>Flowers & Goods"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Contact"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}